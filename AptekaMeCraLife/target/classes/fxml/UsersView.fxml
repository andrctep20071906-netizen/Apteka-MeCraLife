<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mecralife.controllers.UsersController">

    <HBox spacing="10">
        <Button text="← Назад" onAction="#goBack"/>
        <Label text="Управление пользователями" styleClass="section-title"/>
    </HBox>

    <Separator/>

    <HBox spacing="20">
        <TableView fx:id="tableView" prefWidth="600" prefHeight="400">
            <columns>
                <TableColumn text="ID" fx:id="colId" prefWidth="50"/>
                <TableColumn text="Email" fx:id="colEmail" prefWidth="200"/>
                <TableColumn text="ФИО" fx:id="colName" prefWidth="200"/>
                <TableColumn text="Телефон" fx:id="colPhone" prefWidth="120"/>
                <TableColumn text="Бонусы" fx:id="colBonus" prefWidth="80"/>
                <TableColumn text="Роль" fx:id="colRole" prefWidth="100"/>
            </columns>
        </TableView>

        <VBox spacing="10" prefWidth="300">
            <Label text="Добавление/Редактирование пользователя:"/>
            <TextField fx:id="emailField" promptText="Email"/>
            <TextField fx:id="nameField" promptText="ФИО"/>
            <TextField fx:id="phoneField" promptText="Телефон"/>
            <PasswordField fx:id="passwordField" promptText="Пароль"/>
            <TextField fx:id="bonusField" promptText="Бонусы"/>
            <ComboBox fx:id="roleCombo" prefWidth="200"/>

            <HBox spacing="10">
                <Button text="Добавить" onAction="#onAddUser"/>
                <Button text="Редактировать" onAction="#onEditUser"/>
                <Button text="Обновить" onAction="#onUpdateUser"/>
                <Button text="Удалить" onAction="#onDeleteUser"/>
            </HBox>
        </VBox>
    </HBox>

</VBox>